{
  "name": "MyMathsBook (TeX Live)",
  "image": "texlive/texlive:latest-full",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode",
      "userUid": "automatic",
      "userGid": "automatic",
      "installZsh": true,
      "configureZshAsDefaultShell": false
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "runArgs": ["--init"],
  "containerEnv": { "TZ": "Europe/Paris" },
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop",
        "valentjn.vscode-ltex",
        "anthropic.claude-code"
      ],
      "settings": {
        "files.eol": "\n",
        "[latex]": {
          "editor.wordWrap": "on",
          "editor.tabSize": 2
        },
        "ltex.language": "fr"
      }
    }
  },
  "postCreateCommand": "latexmk --version >/dev/null && makeglossaries --version >/dev/null 2>&1 && chktex --version >/dev/null && (command -v claude >/dev/null 2>&1 || curl -fsSL https://claude.ai/install.sh | bash) && echo 'TeX Live + Claude Code devcontainer prêt.'",
  "postStartCommand": "sudo chown -R vscode:vscode /workspaces/MyMathsBook"
}
