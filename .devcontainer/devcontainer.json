{
  "name": "MyMathsBook (TeX Live)",
  "build": { "dockerfile": "Dockerfile" },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "runArgs": ["--init"],
  "containerEnv": { "TZ": "Europe/Paris" },
  "remoteEnv": { "PATH": "${containerEnv:HOME}/.local/bin:${containerEnv:PATH}" },
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop",
        "valentjn.vscode-ltex",
        "anthropic.claude-code"
      ],
      "settings": {
        "files.eol": "\n",
        "terminal.integrated.defaultLocation": "editor",
        "[latex]": {
          "editor.wordWrap": "on",
          "editor.tabSize": 2
        },
        "ltex.language": "fr"
      }
    }
  },
  "postCreateCommand": "latexmk --version >/dev/null && makeglossaries --version >/dev/null 2>&1 && chktex --version >/dev/null && claude --version >/dev/null && echo 'TeX Live + Claude Code devcontainer prêt.'",
  "postStartCommand": "sudo chown -R vscode:vscode /workspaces/MyMathsBook"
}
