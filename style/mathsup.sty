%==============================================================
%  style/mathsup.sty — Feuille de style commune
%  Thème « Classique » inspiré de theme-book.pdf :
%  monochrome · serif Latin Modern · sobre · sans encadrés colorés
%  (Mêmes macros que la version couleur : les leçons sont inchangées.)
%==============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style/mathsup}[2026/06/02 Style Maths Sup/Spe — Classique]

%=== PACKAGES FONDAMENTAUX ===================================
\usepackage[T1]{fontenc}
\usepackage[french]{babel}
\usepackage{lmodern}                 % Latin Modern : aspect Computer Modern classique
% Latin Modern n'a pas de petites capitales grasses (bx/sc) ni italiques (m/scit) :
% on déclare des substitutions vers les variantes existantes pour éviter les
% « Font shape undefined » (PC penchées pour l'italique, PC maigres pour le gras).
% On force d'abord le chargement de t1lmr.fd (sinon la famille T1/lmr est inconnue).
{\usefont{T1}{lmr}{m}{n}}
\DeclareFontShape{T1}{lmr}{m}{scit}{<->ssub*lmr/m/scsl}{}
\DeclareFontShape{T1}{lmr}{bx}{scit}{<->ssub*lmr/m/scsl}{}
\DeclareFontShape{T1}{lmr}{b}{scit}{<->ssub*lmr/m/scsl}{}
\DeclareFontShape{T1}{lmr}{bx}{sc}{<->ssub*lmr/m/sc}{}
\DeclareFontShape{T1}{lmr}{b}{sc}{<->ssub*lmr/m/sc}{}
\usepackage{microtype}
\usepackage{setspace}
\setstretch{1.1}
\usepackage{amsmath, amssymb, amsthm}
\allowdisplaybreaks  % autorise la coupure des alignements multi-lignes (mieux dans les encadrés)
\DeclareMathOperator{\pgcd}{pgcd}
\DeclareMathOperator{\ppcm}{ppcm}
\usepackage[dvipsnames]{xcolor}
\usepackage{tikz}
\usepackage[most]{tcolorbox}  % gère aussi les barres latérales (breakable, robuste sur sauts de page)
\usepackage{datetime}
\usepackage{enumitem}
\usepackage{titletoc}
% imakeidx AVANT hyperref : indispensable pour que les numéros de page de
% l'index soient encapsulés par \hyperpage (donc cliquables).
\usepackage{imakeidx}
\usepackage{hyperref}
% nonumberlist : glossaire = lexique de définitions, sans numéros de page
% (les leçons n'utilisent pas \gls, les numéros n'auraient aucun sens).
\usepackage[acronym, toc, nonumberlist]{glossaries}

%=== MISE EN PAGE ============================================
\usepackage[top=3cm, bottom=3cm, left=3cm, right=3cm]{geometry}
\raggedbottom
\emergencystretch=2em

%=== PALETTE SÉMANTIQUE (thème classique rehaussé) ===========
% Couleurs par catégorie : théorèmes (bleu), preuves & exemples (vert),
% exercices & contre-exemples (rouge). Sobres, dérivées du thème d'origine.
\definecolor{thmblue}{HTML}{2E5FA0}    % théorèmes (bleu medium, plus clair)
\definecolor{proofgreen}{HTML}{2E6B3E} % preuves & exemples
\definecolor{exred}{HTML}{8B2020}      % exercices & contre-exemples
\definecolor{goldaccent}{gray}{0.45}
\definecolor{theorembg}{HTML}{FFFFFF}
\definecolor{rulegray}{gray}{0.55}
\definecolor{ideegray}{gray}{0.32}     % « Idée de la preuve » (italique gris foncé)
% Le TEXTE (labels compris) reste entièrement noir : seuls les cadres et les
% barres latérales portent la couleur. Les noms employés dans les leçons sont
% donc redirigés vers le noir.
\colorlet{navyblue}{black}        % labels « Preuve. » / « Exemples. » → noir
\colorlet{counterred}{black}      % labels « Contre-exemples. »        → noir
\colorlet{exgreen}{black}

%=== HYPERREF (liens noirs, discrets) ========================
\hypersetup{
  colorlinks=true,
  linkcolor=black,
  citecolor=black,
  urlcolor=black,
}

%=== TABLE DES MATIÈRES (classique, monochrome) ==============
\titlecontents{part}[0em]
  {\addvspace{14pt}%
   \noindent\rlap{\textcolor{rulegray}{\rule{\linewidth}{0.4pt}}}\\[-2pt]%
   \large\bfseries\scshape}
  {Partie \thecontentslabel\quad}{}
  {\hfill\contentspage}
  [\noindent\rlap{\textcolor{rulegray}{\rule{\linewidth}{0.4pt}}}\addvspace{4pt}]

\titlecontents{chapter}[2.2em]
  {\addvspace{3pt}\bfseries}
  {\contentslabel{1.8em}}{}
  {\titlerule*[5pt]{.}\contentspage}
  [\addvspace{1pt}]

\titlecontents{section}[4.5em]
  {\small}
  {\contentslabel{2.2em}}
  {\hspace{0pt}}
  {\titlerule*[5pt]{.}\contentspage}
  []

%=== LISTES ==================================================
\setlist[itemize]{itemsep=4pt, topsep=6pt, leftmargin=1.6em}
\setlist[enumerate]{itemsep=5pt, topsep=8pt, leftmargin=1.8em,
                    label=\arabic*.}

%=== BOÎTE THÉORÈME (cadre bleu fin, sans fond) ==============
\tcbset{
  thmbox/.style={
    enhanced,
    colback=white,
    colframe=thmblue,
    boxrule=1.4pt,
    arc=0pt, outer arc=0pt,
    grow to left by=10pt, grow to right by=10pt,  % un peu plus large que le texte
    left=12pt, right=12pt, top=8pt, bottom=9pt,
    before skip=12pt, after skip=14pt,
    before upper={\setlist[itemize]{itemsep=1pt,topsep=3pt}\setlist[enumerate]{itemsep=1pt,topsep=3pt}},
  }
}

%=== BARRES LATÉRALES (tcolorbox) — filet gauche discret =====
% Démonstrations, exemples, contre-exemples, exercices : simple filet
% gauche, sans fond. tcolorbox « breakable » coupe proprement sur les
% sauts de page (contrairement à mdframed sur les démos > 1 page).
% Les leçons écrivent \begin{mdframed}[style=proofbar] : on conserve
% cette syntaxe via une clé « style » et un environnement mdframed aliasé.
\tcbset{
  barbase/.style={breakable, enhanced, colback=white, frame hidden,
    boxrule=0pt, sharp corners, boxsep=0pt,
    left=14pt, right=0pt, top=2pt, bottom=6pt,
    before skip=4pt, after skip=10pt},
  proofbar/.style={barbase},                          % preuves → indenté, sans trait
  exbar/.style={barbase, after skip=8pt},             % exemples → indenté, sans trait
  cexbar/.style={barbase, after skip=8pt},            % contre-exemples → indenté, sans trait
  exobar/.style={barbase, bottom=8pt, after skip=6pt}, % exercices → indenté, sans trait
  style/.style={#1},      % permet \begin{mdframed}[style=proofbar]
  nobreak/.style={unbreakable},  % compat. clé mdframed nobreak=true
}
\newenvironment{mdframed}[1][]{\tcolorbox[#1]}{\endtcolorbox}

%=== COMMANDES MATHÉMATIQUES =================================
\newcommand{\dd}{\mathop{}\!\mathrm{d}}

%=== COMMANDES STRUCTURANTES =================================

% Titre de sous-partie : titre gras serif, sans numéro ni couleur
% (#1 = ancienne couleur, ignorée ; #2 = numéro, ignoré ; #3 = titre)
\newcommand{\secnum}[3]{%
  \vspace{20pt}
  \noindent{\large\bfseries #3}%
  \par\vspace{8pt}
}

% Sous-rubrique : intitulé gras en amorce de paragraphe
\newcommand{\rubriq}[1]{%
  \vspace{8pt}
  \noindent{\bfseries #1.}\enspace
}

% Blocs d'intuition (idée de preuve, signification) : paragraphe en italique
% gris foncé. Environnement (donc groupe) pour que le style ne déborde pas.
\newenvironment{intuitionbloc}[1]{%
  \par\vspace{8pt}\normalfont\itshape\color{ideegray}%
  \noindent\textbf{#1.}\enspace\ignorespaces
}{\par\vspace{2pt}}
\newenvironment{ideepreuve}{\intuitionbloc{Idée de la preuve}}{\endintuitionbloc}
\newenvironment{significationintuitive}{\intuitionbloc{Signification intuitive}}{\endintuitionbloc}

% Étiquette de bloc d'exercices
\newcommand{\exolabel}{\noindent{\bfseries Exercices.}}

% Séparateur sobre : simple respiration verticale
\newcommand{\decsep}{%
  \par\vspace{12pt}
  \begin{center}
    \textcolor{rulegray}{$\ast\quad\ast\quad\ast$}
  \end{center}
  \vspace{4pt}
}

% En-tête de leçon : titre centré, sous-titre en italique, filet fin
\newcommand{\lecontitle}[2]{%
  \phantomsection\addcontentsline{toc}{section}{#1}%
  \thispagestyle{empty}
  \vspace*{4pt}
  \begin{center}
    {\fontsize{22}{27}\selectfont\bfseries #1}\\[8pt]
    {\large\itshape #2}\\[10pt]
    \textcolor{rulegray}{\rule{0.55\textwidth}{0.4pt}}
  \end{center}
  \vspace{16pt}
}

% Pied de page de leçon : note discrète centrée
\newcommand{\leconfooter}[1]{%
  \vfill
  \noindent\textcolor{rulegray}{\rule{\textwidth}{0.4pt}}
  \begin{center}
    \small\itshape\color{black!55}
    Fiche de cours \quad|\quad #1
  \end{center}
}

