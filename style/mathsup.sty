%==============================================================
%  style/mathsup.sty — Feuille de style commune
%  Palette bleu & or · Barres latérales · Boîte théorème
%==============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mathsup}[2024/01/01 Style Maths Sup/Spe]

%=== PACKAGES FONDAMENTAUX ===================================
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage[french]{babel}
\usepackage{mathpazo}
\usepackage{microtype}
\usepackage{setspace}
\setstretch{1.3}
\usepackage{amsmath, amssymb, amsthm}
\usepackage[dvipsnames]{xcolor}
\usepackage[most]{tcolorbox}
\usepackage[framemethod=tikz]{mdframed}
\usepackage{tikz}
\usepackage{datetime}
\usepackage{enumitem}
\usepackage{titletoc}
\usepackage{hyperref}
\usepackage{imakeidx}
\usepackage[acronym, toc]{glossaries}

%=== MISE EN PAGE ============================================
\usepackage[top=3cm, bottom=3.2cm, left=2.8cm, right=2.8cm]{geometry}

%=== TABLE DES MATIÈRES ======================================
\titlecontents{part}[0em]
  {\addvspace{14pt}%
   \noindent\textcolor{goldaccent!60}{\rule{\textwidth}{0.4pt}}\\[-2pt]%
   \normalsize\bfseries\color{navyblue}}
  {Partie \thecontentslabel\quad}{}
  {\hfill\contentspage}
  [\noindent\textcolor{goldaccent!60}{\rule{\textwidth}{0.4pt}}\addvspace{4pt}]

\titlecontents{chapter}[2.2em]
  {\addvspace{3pt}\bfseries\color{navyblue!80}}
  {\contentslabel{1.8em}}{}
  {\titlerule*[5pt]{.}\contentspage}
  [\addvspace{1pt}]

\titlecontents{section}[4.5em]
  {\small\color{black!70}}
  {\contentslabel{2.2em}}
  {\hspace{0pt}}
  {\titlerule*[5pt]{.}\contentspage}
  []

%=== LISTES ==================================================
\setlist[itemize]{itemsep=5pt, topsep=7pt, leftmargin=1.6em}
\setlist[enumerate]{itemsep=6pt, topsep=9pt, leftmargin=1.8em,
                    label=\textcolor{navyblue}{\arabic*.}}

%=== PALETTE =================================================
\definecolor{navyblue}{HTML}{1A2E4A}
\definecolor{goldaccent}{HTML}{C9A84C}
\definecolor{exgreen}{HTML}{2E6B3E}
\definecolor{counterred}{HTML}{8B2020}
\definecolor{theorembg}{HTML}{EDF2F9}

%=== HYPERREF ================================================
\hypersetup{
  colorlinks=true,
  linkcolor=NavyBlue,
  citecolor=NavyBlue,
  urlcolor=NavyBlue,
}

%=== BOÎTE THÉORÈME ==========================================
\tcbset{
  thmbox/.style={
    enhanced,
    colback=theorembg,
    colframe=navyblue,
    boxrule=1pt,
    arc=3pt,
    left=10pt, right=10pt, top=7pt, bottom=8pt,
    before skip=10pt, after skip=12pt,
    before upper={\setlist[itemize]{itemsep=1pt,topsep=3pt}\setlist[enumerate]{itemsep=1pt,topsep=3pt}},
  }
}

%=== BARRES LATÉRALES (mdframed) =============================

\mdfdefinestyle{proofbar}{
  topline=false, bottomline=false, rightline=false,
  linecolor=navyblue, linewidth=3pt,
  innerleftmargin=14pt, innerrightmargin=0pt,
  innertopmargin=2pt, innerbottommargin=6pt,
  backgroundcolor=white,
  skipabove=4pt, skipbelow=10pt,
}

\mdfdefinestyle{exbar}{
  topline=false, bottomline=false, rightline=false,
  linecolor=exgreen, linewidth=3pt,
  innerleftmargin=14pt, innerrightmargin=0pt,
  innertopmargin=2pt, innerbottommargin=6pt,
  backgroundcolor=white,
  skipabove=4pt, skipbelow=8pt,
}

\mdfdefinestyle{cexbar}{
  topline=false, bottomline=false, rightline=false,
  linecolor=counterred, linewidth=3pt,
  innerleftmargin=14pt, innerrightmargin=0pt,
  innertopmargin=2pt, innerbottommargin=6pt,
  backgroundcolor=white,
  skipabove=4pt, skipbelow=8pt,
}

\mdfdefinestyle{exobar}{
  topline=false, bottomline=false, rightline=false,
  linecolor=goldaccent, linewidth=3pt,
  innerleftmargin=14pt, innerrightmargin=0pt,
  innertopmargin=2pt, innerbottommargin=8pt,
  backgroundcolor=white,
  skipabove=4pt, skipbelow=6pt,
}

%=== COMMANDES STRUCTURANTES =================================

% Numéro de section avec cercle coloré
\newcommand{\secnum}[3]{%
  \vspace{22pt}
  \noindent
  \begin{tikzpicture}[baseline=(n.base)]
    \node[
      circle, fill=#1, text=white,
      font=\small\bfseries,
      inner sep=4pt,
      minimum size=20pt
    ] (n) {#2};
  \end{tikzpicture}
  \hspace{8pt}%
  {\large\bfseries\color{navyblue} #3}%
  \par\vspace{4pt}
  \noindent\textcolor{#1!40}{\rule{\textwidth}{0.5pt}}
  \vspace{8pt}
}

% Sous-rubrique en gras bleu
\newcommand{\rubriq}[1]{%
  \vspace{10pt}
  \noindent{\bfseries\color{navyblue} #1.}\enspace
}

% Séparateur décoratif or
\newcommand{\decsep}{%
  \vspace{14pt}
  \begin{center}
    \textcolor{goldaccent}{%
      \rule{40pt}{0.5pt}\quad\textbullet\quad\rule{40pt}{0.5pt}}
  \end{center}
  \vspace{6pt}
}

% En-tête de leçon (titre, sous-titre, filet or)
\newcommand{\lecontitle}[2]{%
  \addcontentsline{toc}{section}{#1}%
  \thispagestyle{empty}
  \vspace*{4pt}
  \begin{center}
    {\fontsize{23}{28}\selectfont\bfseries\color{navyblue} #1}\\[8pt]
    {\large\itshape\color{navyblue!60} #2}\\[10pt]
    \begin{tikzpicture}
      \draw[goldaccent, line width=1.5pt] (0,0) -- (4,0);
      \fill[goldaccent] (2,0) circle (2.5pt);
      \draw[navyblue!25, line width=0.5pt] (-1,0) -- (0,0) (4,0) -- (5,0);
    \end{tikzpicture}
  \end{center}
  \vspace{18pt}
}

% Pied de page de leçon
\newcommand{\leconfooter}[1]{%
  \vfill
  \noindent\textcolor{navyblue!20}{\rule{\textwidth}{0.4pt}}
  \begin{center}
    \small\color{navyblue!50}
    Fiche de cours — Analyse réelle \quad|\quad #1
  \end{center}
}
